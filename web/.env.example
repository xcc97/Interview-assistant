# nod 点头 Web 前端环境变量示例

# API 地址。本地开发示例：http://localhost:8080
# 线上部署示例：https://api.your-domain.com
VITE_API_BASE_URL=http://localhost:8080

# 客户端密钥需要与服务端配置保持一致。
# 上线前请使用强随机值，并避免提交真实生产密钥。
VITE_CLIENT_SECRET=change-me-before-production

# 是否在订单页展示“完成支付”测试入口。
# 本地联调可设为 true；生产环境必须设为 false 或直接不配置。
VITE_ENABLE_MOCK_PAYMENT=false
