# nod 点头后端上线环境变量示例

# 服务端口
SERVER_PORT=8080

# 数据库
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/interview_assistant?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

# 安全配置：生产环境必须替换为强随机值
INTERVIEW_ASSISTANT_CLIENT_SECRET=change-me-before-production
INTERVIEW_ASSISTANT_JWT_SECRET=change-this-jwt-secret-to-a-long-random-string-before-production
INTERVIEW_ASSISTANT_JWT_EXPIRE_SECONDS=7200

# 管理员手机号，多个用英文逗号分隔。只有管理员可以访问 /api/admin/**。
INTERVIEW_ASSISTANT_ADMIN_PHONES=13800138000

# 阿里云实时语音识别
ALIYUN_NLS_APP_KEY=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_ENDPOINT=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1

# 百炼 / DashScope 大模型
BAILIAN_API_KEY=
BAILIAN_MODEL=deepseek-v3
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 支付公共回调域名，必须是微信/支付宝可以访问的 HTTPS 域名
PAYMENT_PUBLIC_BASE_URL=https://api.your-domain.com

# 模拟支付开关：生产环境必须 false
PAYMENT_MOCK_ENABLED=false

# 待支付订单自动关闭，默认 30 分钟；调度默认每 60 秒执行一次
PAYMENT_ORDER_TIMEOUT_MINUTES=30
PAYMENT_ORDER_MAINTENANCE_FIXED_DELAY_MS=60000

# 微信支付 Native
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PRIVATE_CERT_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
# 微信支付平台证书，用于校验回调签名；生产必须配置。
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_CALLBACK_SIGNATURE_REQUIRED=true
WECHAT_PAY_NOTIFY_PATH=/api/payment/wechat/notify

# 支付宝电脑网站支付
ALIPAY_ENABLED=false
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_PATH=/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://your-domain.com/orders
