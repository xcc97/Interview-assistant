# nod 点头后端生产环境变量模板
# 使用方法：复制到服务器 /opt/interview-assistant/server/.env，并替换所有 change-me / your-domain / 空值。
# 注意：真实 .env、支付私钥、证书文件不要提交到 Git。

SERVER_PORT=8080

# MySQL 生产库。建议创建专用低权限用户，不要使用 root。
SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/interview_assistant?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=interview_assistant
SPRING_DATASOURCE_PASSWORD=change-me-strong-db-password

# 生产环境建议先保留 update；稳定后迁移到 Flyway/Liquibase 再改 validate。
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# 安全密钥：必须使用强随机值。前端 VITE_CLIENT_SECRET 需与 INTERVIEW_ASSISTANT_CLIENT_SECRET 一致。
INTERVIEW_ASSISTANT_CLIENT_SECRET=change-me-generate-32-plus-random-chars
INTERVIEW_ASSISTANT_JWT_SECRET=change-me-generate-64-plus-random-chars
INTERVIEW_ASSISTANT_JWT_EXPIRE_SECONDS=7200
INTERVIEW_ASSISTANT_ADMIN_PHONES=13800138000

# 阿里云实时语音识别
ALIYUN_NLS_APP_KEY=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_NLS_ENDPOINT=wss://nls-gateway-cn-shanghai.aliyuncs.com/ws/v1

# 百炼 / DashScope 大模型
BAILIAN_API_KEY=
BAILIAN_MODEL=deepseek-v3
BAILIAN_ENDPOINT=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 支付公共回调域名：必须是公网 HTTPS，且支付平台后台配置的回调地址与这里一致。
PAYMENT_PUBLIC_BASE_URL=https://api.your-domain.com
PAYMENT_MOCK_ENABLED=false
PAYMENT_ORDER_TIMEOUT_MINUTES=30
PAYMENT_ORDER_MAINTENANCE_FIXED_DELAY_MS=60000

# 支付宝电脑网站支付。建议第一阶段优先打通支付宝。
ALIPAY_ENABLED=true
ALIPAY_APP_ID=
# 支持一行 PEM 或去掉头尾后的纯 base64 私钥；注意 systemd EnvironmentFile 不适合多行值。
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do
ALIPAY_NOTIFY_PATH=/api/payment/alipay/notify
ALIPAY_RETURN_URL=https://www.your-domain.com/orders

# 微信支付 Native。未接入前保持 false。
WECHAT_PAY_ENABLED=false
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PRIVATE_KEY_PATH=/opt/interview-assistant/certs/wechat/apiclient_key.pem
WECHAT_PAY_PRIVATE_CERT_PATH=/opt/interview-assistant/certs/wechat/apiclient_cert.pem
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PLATFORM_CERT_PATH=/opt/interview-assistant/certs/wechat/wechatpay_platform.pem
WECHAT_PAY_CALLBACK_SIGNATURE_REQUIRED=true
WECHAT_PAY_NOTIFY_PATH=/api/payment/wechat/notify
